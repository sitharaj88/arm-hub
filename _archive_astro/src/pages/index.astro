---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Terminal from '~/components/Terminal.astro';
import Card from '~/components/Card.astro';
import Stat from '~/components/Stat.astro';
import CoreCompare from '~/components/CoreCompare.astro';
import MemoryMap from '~/components/MemoryMap.astro';
import RegisterMap from '~/components/RegisterMap.astro';
import { sections } from '~/utils/nav';

const featured = sections;

const nvicFields = [
  { bits: '31:24', name: 'PRI_n+3', access: 'RW' as const, reset: '0x00', description: 'Priority of interrupt n+3 (upper bits significant).' },
  { bits: '23:16', name: 'PRI_n+2', access: 'RW' as const, reset: '0x00', description: 'Priority of interrupt n+2.' },
  { bits: '15:8',  name: 'PRI_n+1', access: 'RW' as const, reset: '0x00', description: 'Priority of interrupt n+1.' },
  { bits: '7:0',   name: 'PRI_n',   access: 'RW' as const, reset: '0x00', description: 'Priority of interrupt n. Only the upper bits implemented (vendor-defined, typically 3–8).' },
];

const cortexMMap = [
  { start: '0xE010_0000', end: '0xFFFF_FFFF', name: 'Vendor / system',   detail: 'Implementation-defined system region.',         kind: 'system' as const },
  { start: '0xE000_0000', end: '0xE00F_FFFF', name: 'Private Peripheral Bus', detail: 'NVIC, SCB, SysTick, ITM, DWT, TPIU, FPB.', kind: 'system' as const },
  { start: '0xA000_0000', end: '0xDFFF_FFFF', name: 'External device',   detail: 'Shareable, non-cacheable by default.',          kind: 'external' as const },
  { start: '0x6000_0000', end: '0x9FFF_FFFF', name: 'External RAM',      detail: 'FMC / FSMC / OSPI / QSPI.',                     kind: 'external' as const },
  { start: '0x4000_0000', end: '0x5FFF_FFFF', name: 'Peripheral',        detail: 'GPIO, UART, SPI, I²C, timers, DMA, USB…',       kind: 'periph' as const },
  { start: '0x2000_0000', end: '0x3FFF_FFFF', name: 'SRAM',              detail: 'Bit-banded on M3/M4 (0x2000_0000–0x200F_FFFF).', kind: 'sram' as const },
  { start: '0x0000_0000', end: '0x1FFF_FFFF', name: 'Code',              detail: 'Flash, system memory, bootloader.',             kind: 'code' as const },
];
---
<BaseLayout title="armhub.dev — the modern reference for ARM microcontroller development" description="A world-class open reference for ARM developers: architecture, peripherals, RTOSes, toolchains, and vendor families. Built for engineers who actually ship firmware.">
  <!-- HERO -->
  <section class="relative overflow-hidden border-b border-line/70">
    <div class="absolute inset-0 grid-bg pointer-events-none" />
    <div class="absolute inset-0 bg-radial-fade pointer-events-none" />
    <div class="container-page relative grid items-center gap-8 sm:gap-10 py-12 sm:py-16 md:py-24 lg:grid-cols-[1.05fr_1fr]">
      <div>
        <div class="inline-flex items-center gap-2 rounded-full border border-line bg-surface/60 px-3 py-1 font-mono text-[0.7rem] uppercase tracking-wider text-ink-muted">
          <span class="h-1.5 w-1.5 rounded-full bg-brand animate-pulse-slow" />
          v0.1 · public preview · ARMv6-M → ARMv9-A
        </div>
        <h1 class="mt-5 font-display text-[2.25rem] sm:text-5xl md:text-6xl font-semibold leading-[1.08] sm:leading-[1.05] tracking-tight text-balance">
          The modern reference for
          <span class="bg-gradient-to-r from-brand via-brand-soft to-accent bg-clip-text text-transparent">ARM development</span>.
        </h1>
        <p class="mt-4 sm:mt-5 max-w-xl text-base sm:text-lg text-ink-muted text-balance">
          One open, opinionated home for everything between the silicon and your firmware — Cortex-M, Cortex-A, Cortex-R,
          peripherals, RTOSes, toolchains, and the vendor families you actually use.
        </p>
        <div class="mt-6 sm:mt-7 flex flex-wrap items-center gap-2 sm:gap-3">
          <a href="/docs/architecture/isa-family/" class="btn-primary">
            <span class="sm:hidden">Get started</span>
            <span class="hidden sm:inline">Start with the architecture</span>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="h-4 w-4"><path d="M5 12h14M13 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
          <a href="/docs/cortex-m/lineup/" class="btn">Explore Cortex-M</a>
          <button id="search-trigger-hero" class="hidden sm:inline-flex btn font-mono text-xs">
            <kbd class="kbd">⌘</kbd><kbd class="kbd">K</kbd>
            <span class="ml-1">to search</span>
          </button>
        </div>
        <dl class="mt-8 sm:mt-10 grid max-w-xl grid-cols-3 gap-2 sm:gap-3">
          <Stat value="9" label="core families" sub="M0 → M85, A & R" />
          <Stat value="120+" label="topics" sub="and counting" />
          <Stat value="∞" label="open source" sub="MIT + CC BY 4.0" />
        </dl>
      </div>

      <div class="relative">
        <Terminal title="armhub ~ /docs/cortex-m/nvic">
          <div><span class="text-ink-faint">$</span> <span class="text-ink">arm-none-eabi-gcc</span> <span class="text-brand">-mcpu=cortex-m4</span> <span class="text-accent">-mthumb</span> -O2 -ffunction-sections -c blink.c</div>
          <div class="text-ink-muted">→ thumb-2 · 14 instructions · -fpie disabled</div>
          <br />
          <div><span class="text-ink-faint">$</span> <span class="text-ink">cat</span> startup.s | <span class="text-brand">arm-none-eabi-as</span> -o startup.o</div>
          <div class="text-ink-muted">→ vector table @ 0x0800_0000 · 16 + 240 entries</div>
          <br />
          <div><span class="text-ink-faint">$</span> <span class="text-ink">armhub</span> <span class="text-brand">explain</span> NVIC_IPR0</div>
          <div class="mt-2 rounded-md border border-line/60 bg-bg/60 p-3 text-ink-muted">
            NVIC_IPR0 @ <span class="text-brand">0xE000_E400</span> — Interrupt Priority Register 0.<br />
            Four 8-bit priority slots for IRQs 0–3. Only the upper bits are implemented;
            number depends on <span class="text-accent">__NVIC_PRIO_BITS</span> (typically 3–4 on Cortex-M4).
          </div>
          <br />
          <div><span class="text-ink-faint">$</span> <span class="caret">_</span></div>
        </Terminal>
        <div class="pointer-events-none absolute -inset-4 -z-10 rounded-2xl bg-gradient-to-br from-brand/15 via-transparent to-accent/15 blur-2xl" />
      </div>
    </div>
  </section>

  <!-- WHAT YOU GET -->
  <section class="container-page py-10 sm:py-14 lg:py-16">
    <div class="mb-10 flex items-end justify-between gap-4">
      <div>
        <div class="font-mono text-xs uppercase tracking-wider text-ink-faint">/ what you get</div>
        <h2 class="mt-2 font-display text-2xl sm:text-3xl font-semibold tracking-tight text-balance">Built for engineers who ship firmware.</h2>
      </div>
      <a href="/learn/" class="hidden md:inline-flex items-center gap-1 text-sm text-ink-muted hover:text-brand">See learning paths →</a>
    </div>
    <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
      <Card
        title="Architecture without the fluff"
        description="ARMv6-M through ARMv9-A — exception model, memory ordering, TrustZone, PAC/BTI — written by people who read the reference manuals so you don't have to."
        href="/docs/architecture/isa-family/"
        icon='<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="h-5 w-5"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M9 3v18M15 3v18M3 9h18M3 15h18"/></svg>'
      />
      <Card
        title="Interactive register maps"
        description="Hover a bit, see what it does. Search a peripheral, get the register layout. Beats squinting at PDFs every time."
        href="/docs/cortex-m/nvic/"
        badge="unique"
        icon='<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="h-5 w-5"><path d="M4 7h16M4 12h16M4 17h16M9 4v16M15 4v16"/></svg>'
      />
      <Card
        title="Side-by-side core comparison"
        description="Cortex-M0 to M85, sorted by anything you want. Pick the right core for the right product."
        href="/docs/cortex-m/lineup/"
        icon='<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="h-5 w-5"><path d="M3 6h18M3 12h18M3 18h18"/><circle cx="8" cy="6" r="1.5" fill="currentColor"/><circle cx="14" cy="12" r="1.5" fill="currentColor"/><circle cx="10" cy="18" r="1.5" fill="currentColor"/></svg>'
      />
      <Card
        title="Real code, real toolchains"
        description="Working examples in C, Rust, and assembly — buildable with GCC, LLVM, or vendor IDEs. No pseudocode."
        href="/docs/programming/embedded-c/"
        icon='<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="h-5 w-5"><path d="m8 18-4-6 4-6M16 6l4 6-4 6M14 4l-4 16"/></svg>'
      />
      <Card
        title="Peripheral patterns"
        description="GPIO, UART, SPI, I²C, CAN, DMA — the patterns that actually work in production, and the traps that bite you at 3am."
        href="/docs/peripherals/gpio/"
        icon='<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="h-5 w-5"><rect x="4" y="8" width="16" height="8" rx="1"/><path d="M8 8V4M12 8V4M16 8V4M8 20v-4M12 20v-4M16 20v-4"/></svg>'
      />
      <Card
        title="RTOSes, compared"
        description="FreeRTOS, Zephyr, ThreadX, RT-Thread — when to reach for which, scheduler internals, and integration patterns."
        href="/docs/rtos/landscape/"
        icon='<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="h-5 w-5"><circle cx="12" cy="12" r="9"/><path d="M12 3v3M21 12h-3M12 21v-3M3 12h3M12 12l5-3"/></svg>'
      />
      <Card
        title="Memory maps that breathe"
        description="See where flash, SRAM, peripherals, and the PPB live for any Cortex-M. Then jump into the regions that matter."
        href="/docs/architecture/memory-model/"
        icon='<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="h-5 w-5"><path d="M3 5h18v4H3zM3 11h18v4H3zM3 17h18v4H3z"/></svg>'
      />
      <Card
        title="Toolchain choices, demystified"
        description="GCC vs LLVM vs commercial. Debug probes that actually work. Build systems that don't make you cry."
        href="/docs/tools/toolchains/"
        icon='<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="h-5 w-5"><path d="m6 6 4 4-4 4M14 6l4 4-4 4M22 18H12"/></svg>'
      />
      <Card
        title="Every major vendor family"
        description="STM32, NXP, Nordic, RP2040/RP2350, Renesas, TI, Microchip, Silicon Labs, Infineon — strengths, weaknesses, ecosystems."
        href="/docs/vendors/stm32/"
        icon='<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="h-5 w-5"><rect x="4" y="4" width="16" height="16" rx="1"/><path d="M9 4v16M15 4v16M4 9h16M4 15h16"/></svg>'
      />
    </div>
  </section>

  <!-- LIVE PREVIEW: REGISTER MAP -->
  <section class="container-page py-10 sm:py-14 lg:py-16">
    <div class="mb-8">
      <div class="font-mono text-xs uppercase tracking-wider text-ink-faint">/ live preview · interactive register map</div>
      <h2 class="mt-2 font-display text-2xl sm:text-3xl font-semibold tracking-tight text-balance">Hover a field. Read it. Understand it.</h2>
      <p class="mt-2 max-w-2xl text-ink-muted">
        Every register on armhub is rendered like this — hoverable, focusable, with the bit layout and the table linked.
        Below is <span class="font-mono text-brand">NVIC_IPR0</span>, the first NVIC interrupt-priority register on every Cortex-M.
      </p>
    </div>
    <RegisterMap
      name="NVIC_IPR0"
      address="0xE000_E400"
      width={32}
      reset="0x0000_0000"
      fields={nvicFields}
      caption="Cortex-M4/M7 NVIC — Interrupt Priority Register 0 · see ARMv7-M ARM §B3.4.7"
    />
  </section>

  <!-- LIVE PREVIEW: MEMORY MAP -->
  <section class="container-page py-10 sm:py-14 lg:py-16">
    <div class="grid gap-8 lg:grid-cols-[1fr_1.4fr]">
      <div class="lg:pt-6">
        <div class="font-mono text-xs uppercase tracking-wider text-ink-faint">/ live preview · address space</div>
        <h2 class="mt-2 font-display text-2xl sm:text-3xl font-semibold tracking-tight text-balance">The Cortex-M address space at a glance.</h2>
        <p class="mt-3 text-ink-muted">
          Every Cortex-M shares the same eight 512&nbsp;MB regions. Flash starts at <span class="font-mono text-brand">0x0000_0000</span>,
          SRAM at <span class="font-mono text-brand">0x2000_0000</span>, peripherals at
          <span class="font-mono text-brand">0x4000_0000</span>, and the Private Peripheral Bus — where the NVIC, SysTick, and SCB live —
          sits at <span class="font-mono text-brand">0xE000_0000</span>.
        </p>
        <a href="/docs/architecture/memory-model/" class="mt-4 inline-flex items-center gap-1 text-sm text-brand hover:text-brand-soft">Memory model deep dive →</a>
      </div>
      <MemoryMap title="Generic Cortex-M address space" regions={cortexMMap} />
    </div>
  </section>

  <!-- CORE COMPARE -->
  <section class="container-page py-10 sm:py-14 lg:py-16">
    <div class="mb-6">
      <div class="font-mono text-xs uppercase tracking-wider text-ink-faint">/ pick the right core</div>
      <h2 class="mt-2 font-display text-2xl sm:text-3xl font-semibold tracking-tight text-balance">From M0 to M85, sortable.</h2>
    </div>
    <CoreCompare />
  </section>

  <!-- SYSTEM DESIGNS -->
  <section class="container-page py-10 sm:py-14 lg:py-16">
    <div class="mb-8 flex items-end justify-between gap-4">
      <div>
        <div class="font-mono text-xs uppercase tracking-wider text-ink-faint">/ system designs · real products</div>
        <h2 class="mt-2 font-display text-2xl sm:text-3xl font-semibold tracking-tight text-balance">How real devices are actually built.</h2>
        <p class="mt-2 max-w-2xl text-ink-muted">
          Block diagrams, software stacks, and design tradeoffs for the seven embedded products you've probably touched today.
          Every page traces back to the cores, peripherals, RTOS, and toolchains the rest of armhub covers.
        </p>
      </div>
      <a href="/docs/systems/overview/" class="hidden md:inline-flex items-center gap-1 text-sm text-ink-muted hover:text-brand">See all system designs →</a>
    </div>
    <div class="grid gap-3 md:grid-cols-2 lg:grid-cols-3">
      <Card
        href="/docs/systems/wifi-router/"
        title="Wi-Fi router (Wi-Fi 6)"
        description="Quad Cortex-A53 + dedicated MAC/PHY + NPU offload. Linux/OpenWrt. ~$80–$250 retail."
      />
      <Card
        href="/docs/systems/smartwatch/"
        title="Smartwatch"
        description="Cortex-M33 + BLE radio. 5–15 day battery, sensor fusion, GATT services."
      />
      <Card
        href="/docs/systems/drone-flight-controller/"
        title="Drone flight controller"
        description="Cortex-M7 @ 480 MHz. 8 kHz control loop, IMU+GPS, PX4/ArduPilot."
      />
      <Card
        href="/docs/systems/ev-charger/"
        title="EV charger"
        description="Cortex-M7 + Wi-Fi MCU. J1772 control pilot, RCD, OCPP cloud."
      />
      <Card
        href="/docs/systems/smart-thermostat/"
        title="Smart thermostat"
        description="Cortex-M33 + Thread/Matter radio. Power-stealing, LVGL UI."
      />
      <Card
        href="/docs/systems/automotive-ecu/"
        title="Automotive ECU"
        badge="ASIL"
        description="Cortex-R52 lockstep. CAN-FD, ISO 26262, AUTOSAR Classic, hardware HSM."
      />
      <Card
        href="/docs/systems/motor-drive/"
        title="Industrial motor drive"
        description="Cortex-M4F. FOC at 16–32 kHz, hardware-synced ADC, CANopen/EtherCAT."
      />
    </div>
  </section>

  <!-- BROWSE BY SECTION -->
  <section class="container-page py-10 sm:py-14 lg:py-16">
    <div class="mb-8">
      <div class="font-mono text-xs uppercase tracking-wider text-ink-faint">/ browse</div>
      <h2 class="mt-2 font-display text-2xl sm:text-3xl font-semibold tracking-tight text-balance">Every section, every page.</h2>
    </div>
    <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
      {featured.map((s) => (
        <div class="rounded-xl border border-line bg-surface/60 p-5 shadow-card">
          <div class="flex items-baseline justify-between">
            <h3 class="font-display text-base font-semibold text-ink">{s.title}</h3>
            <span class="font-mono text-[0.65rem] uppercase tracking-wider text-ink-faint">{s.links.length} pages</span>
          </div>
          <p class="mt-1 text-sm text-ink-muted">{s.intro}</p>
          <ul class="mt-3 space-y-1 text-sm">
            {s.links.slice(0, 5).map((l) => (
              <li>
                <a href={l.href} class="flex items-center justify-between rounded-md px-2 py-1 text-ink-muted hover:bg-surface hover:text-brand">
                  <span>{l.title}</span>
                  {l.badge && <span class="font-mono text-[0.6rem] uppercase tracking-wider text-ink-faint">{l.badge}</span>}
                </a>
              </li>
            ))}
            {s.links.length > 5 && (
              <li class="px-2 py-1 font-mono text-xs text-ink-faint">+{s.links.length - 5} more</li>
            )}
          </ul>
        </div>
      ))}
    </div>
  </section>

  <!-- CONTRIBUTE -->
  <section class="container-page py-12 sm:py-16 lg:py-20">
    <div class="surface relative overflow-hidden p-8 md:p-12">
      <div class="absolute inset-0 -z-10 grid-bg opacity-50" />
      <div class="grid items-center gap-6 lg:grid-cols-[1.5fr_1fr]">
        <div>
          <div class="font-mono text-xs uppercase tracking-wider text-ink-faint">/ contribute</div>
          <h2 class="mt-2 font-display text-2xl sm:text-3xl font-semibold tracking-tight text-balance">This site is open. Make it better.</h2>
          <p class="mt-3 max-w-xl text-ink-muted">
            Found a mistake? Have a peripheral pattern that should be canonical? Wrote a Rust example that beats the C one?
            Open a PR. armhub.dev is for working engineers, written by working engineers.
          </p>
          <div class="mt-5 flex flex-wrap items-center gap-3">
            <a href="https://github.com/sitharaj88/armhub" target="_blank" rel="noopener" class="btn-primary">Star on GitHub</a>
            <a href="/contributing/" class="btn">Read the contribution guide</a>
          </div>
        </div>
        <Terminal title="armhub ~ contributing">
          <div><span class="text-ink-faint">$</span> <span class="text-ink">git clone</span> https://github.com/sitharaj88/armhub</div>
          <div><span class="text-ink-faint">$</span> <span class="text-ink">cd</span> armhub <span class="text-ink-faint">&&</span> <span class="text-ink">npm i</span></div>
          <div><span class="text-ink-faint">$</span> <span class="text-brand">npm run dev</span></div>
          <div class="text-ink-muted">→ ready in 0.42s · http://localhost:4321</div>
        </Terminal>
      </div>
    </div>
  </section>

  <script>
    document.getElementById('search-trigger-hero')?.addEventListener('click', () => {
      document.getElementById('search-trigger')?.click();
    });
  </script>
</BaseLayout>

---
interface Props { value: string; label: string; sub?: string }
const { value, label, sub } = Astro.props;
---
<div class="rounded-xl border border-line bg-surface/70 p-3 sm:p-4 shadow-card">
  <div class="font-mono text-xl sm:text-2xl text-ink leading-none">{value}</div>
  <div class="mt-1.5 text-[0.65rem] sm:text-xs uppercase tracking-wider text-ink-faint leading-tight">{label}</div>
  {sub && <div class="mt-1 text-[0.65rem] sm:text-xs text-ink-muted leading-snug">{sub}</div>}
</div>

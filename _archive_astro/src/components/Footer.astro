---
import { sections } from '~/utils/nav';
const year = new Date().getFullYear();
---
<footer class="mt-16 sm:mt-24 border-t border-line bg-bg-subtle/60">
  <div class="container-page py-10 sm:py-14">
    <div class="grid gap-8 sm:gap-10 lg:grid-cols-[1.4fr_3fr]">
      <div>
        <div class="flex items-center gap-2 font-display text-lg font-semibold">
          arm<span class="text-brand">hub</span><span class="text-ink-faint">.dev</span>
        </div>
        <p class="mt-3 max-w-sm text-sm text-ink-muted">
          An open reference for ARM developers — architecture, peripherals, RTOSes, and vendor families,
          assembled in one place by people who ship firmware.
        </p>
        <div class="mt-4 sm:mt-5 flex flex-wrap gap-2">
          <a href="https://github.com/sitharaj88/armhub" target="_blank" rel="noopener" class="pill hover:text-ink hover:border-brand/40 transition">GitHub</a>
          <a href="/rss.xml" class="pill hover:text-ink hover:border-brand/40 transition">RSS</a>
          <a href="/contributing/" class="pill hover:text-ink hover:border-brand/40 transition">Contribute</a>
        </div>
      </div>
      <div class="grid grid-cols-2 gap-x-4 gap-y-6 sm:grid-cols-3 lg:grid-cols-4">
        {sections.slice(0, 8).map((s) => (
          <div>
            <div class="font-mono text-[0.65rem] sm:text-xs uppercase tracking-wider text-ink-faint">{s.title}</div>
            <ul class="mt-2 sm:mt-3 space-y-1.5 text-sm">
              {s.links.slice(0, 4).map((l) => (
                <li><a href={l.href} class="text-ink-muted hover:text-brand">{l.title}</a></li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
    <div class="mt-8 sm:mt-12 flex flex-col items-start justify-between gap-3 border-t border-line/70 pt-5 sm:pt-6 text-xs text-ink-faint sm:flex-row">
      <div>© {year} armhub.dev · Content available under CC BY 4.0 · Code under MIT.</div>
      <div class="font-mono">ARM, Cortex, and TrustZone are trademarks of Arm Limited. armhub.dev is an independent reference site.</div>
    </div>
  </div>
</footer>

---
interface Props {
  href?: string;
  title: string;
  description?: string;
  badge?: string;
  icon?: string;
  class?: string;
}
const { href, title, description, badge, icon, class: cls = '' } = Astro.props;
const Tag = href ? 'a' : 'div';
---
<Tag
  href={href}
  class:list={[
    'group relative block overflow-hidden rounded-xl border border-line bg-surface/70 p-5 shadow-card transition',
    href ? 'hover:border-brand/40 hover:bg-surface hover:shadow-panel' : '',
    cls,
  ]}
>
  <div class="flex items-start gap-3">
    {icon && (
      <span class="grid h-9 w-9 shrink-0 place-items-center rounded-lg border border-line/70 bg-bg-subtle text-brand">
        <Fragment set:html={icon} />
      </span>
    )}
    <div class="min-w-0 flex-1">
      <div class="flex items-center gap-2">
        <h3 class="font-display text-base font-semibold text-ink group-hover:text-brand transition">{title}</h3>
        {badge && <span class="pill pill-accent text-[0.65rem]">{badge}</span>}
      </div>
      {description && <p class="mt-1 text-sm text-ink-muted">{description}</p>}
    </div>
    {href && (
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="h-4 w-4 shrink-0 text-ink-faint translate-x-0 group-hover:translate-x-0.5 group-hover:text-brand transition">
        <path d="M5 12h14M13 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    )}
  </div>
</Tag>
